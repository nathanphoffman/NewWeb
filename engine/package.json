{
  "name": "newweb-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:js": "esbuild src/engine.ts --bundle --format=esm --outfile=build/engine.bundle.js",
    "build:html": "node scripts/build-html.js",
    "build": "npm run typecheck && npm run build:js && npm run build:html",
    "watch": "esbuild src/engine.ts --bundle --format=esm --outfile=build/engine.bundle.js --watch"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.0.0"
  }
}
