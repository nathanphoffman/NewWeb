{
  "name": "newweb-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:js": "esbuild src/engine.ts --bundle --minify --format=esm --loader:.woff2=dataurl --loader:.woff=dataurl --outfile=build/engine.bundle.js",
    "build:html": "node scripts/build-html.js src/index.html build/index.html build/engine.bundle.js",
    "build": "npm run typecheck && npm run build:js && npm run build:html",
    "watch": "esbuild src/engine.ts --bundle --format=esm --loader:.woff2=dataurl --loader:.woff=dataurl --outfile=build/engine.bundle.js --watch"
  },
  "devDependencies": {
    "@types/prismjs": "^1.26.6",
    "esbuild": "^0.25.0",
    "prismjs": "^1.30.0",
    "typescript": "^5.0.0"
  }
}
