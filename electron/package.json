{
  "name": "newweb-electron",
  "version": "1.0.0",
  "description": "NewWeb desktop browser",
  "author": "Nate Hoffman",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "me.nathanhoffman.newweb",
    "productName": "NewWeb",
    "afterPack": "./after-pack.js",
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      { "from": "../index.html",                       "to": "index.html" },
      { "from": "../welcome.md",                        "to": "welcome.md" },
      { "from": "../engine/build/pkg/engine_bg.wasm",   "to": "engine/build/pkg/engine_bg.wasm" }
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Network"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
